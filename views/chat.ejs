<%- include('partials/header') %>

<div class="space-y-6 max-w-4xl mx-auto animate-[fadeIn_0.5s_ease-out]">
  <!-- Encabezado del Chat -->
  <div class="flex items-center justify-between border-b border-spotify-highlight/40 pb-5">
    <div>
      <h1 class="font-title font-extrabold text-2xl tracking-tight text-white flex items-center gap-2">
        <i data-lucide="message-square" class="text-spotify-orange w-6 h-6"></i>
        <span>Canal de Soporte en Vivo</span>
      </h1>
      <p class="text-xs text-gray-400 mt-1">Valida la compatibilidad de repuestos para camiones pesados y buses en tiempo real.</p>
    </div>
    <div class="flex items-center gap-2 text-xs text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3.5 py-1.5 rounded-full select-none font-bold">
      <span class="w-2 h-2 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399] animate-pulse"></span>
      <span>Conexión Activa</span>
    </div>
  </div>

  <!-- Contenedor Principal de la Ventana de Chat (Estilo Spotify macOS) -->
  <div class="bg-spotify-dark border border-spotify-highlight/50 rounded-2xl shadow-xl overflow-hidden flex flex-col h-[60vh] max-h-[600px]">
    
    <!-- Barra superior de la sala -->
    <div class="bg-spotify-dark/95 border-b border-spotify-highlight/40 px-5 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <div class="w-2 h-2 rounded-full bg-red-500"></div>
        <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
        <div class="w-2 h-2 rounded-full bg-green-500"></div>
        <span class="text-xs font-semibold text-gray-400 ml-2 font-mono">technical-compatibility-room</span>
      </div>
      <a href="/dashboard" class="flex items-center gap-1.5 text-xs font-bold text-gray-400 hover:text-white transition-colors">
        <i data-lucide="chevron-left" class="w-3.5 h-3.5"></i> Volver al Catálogo
      </a>
    </div>

    <!-- Área de Mensajes -->
    <div id="chat-messages" class="flex-1 p-5 overflow-y-auto space-y-4 bg-spotify-black/40">
      <!-- Mensaje Inicial de Bienvenida -->
      <div class="flex items-start gap-3 max-w-[75%] animate-[fadeIn_0.3s_ease-out]">
        <div class="w-8 h-8 rounded-full bg-spotify-highlight/60 flex items-center justify-center text-spotify-orange border border-spotify-highlight flex-shrink-0">
          <i data-lucide="shield-check" class="w-4 h-4"></i>
        </div>
        <div class="bg-spotify-dark border border-spotify-highlight/60 rounded-r-xl rounded-bl-xl p-3.5 shadow-md">
          <div class="flex justify-between items-center gap-4 mb-1">
            <span class="text-xs font-bold text-spotify-orange">Sistema de Soporte</span>
            <span class="text-[9px] text-gray-600 font-semibold"><%= new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
          </div>
          <p class="text-sm text-gray-300 leading-relaxed">
            ¡Hola **<%= user.name %>**! Has ingresado al chat de soporte en vivo. Escribe tus dudas acerca de dimensiones, torques, stock o compatibilidad de repuestos para que un especialista técnico te confirme.
          </p>
        </div>
      </div>
    </div>

    <!-- F5: Indicador "está escribiendo..." con animación de puntos -->
    <div id="typing-indicator" class="hidden px-5 py-2.5 bg-spotify-black/50 border-t border-spotify-highlight/20">
      <div class="flex items-center gap-2.5">
        <div class="flex items-center gap-0.5">
          <span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-bounce" style="animation-delay:0ms; animation-duration:0.8s"></span>
          <span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-bounce" style="animation-delay:160ms; animation-duration:0.8s"></span>
          <span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-bounce" style="animation-delay:320ms; animation-duration:0.8s"></span>
        </div>
        <span id="typing-text" class="text-[11px] text-gray-500 font-medium italic"></span>
      </div>
    </div>

    <!-- Pie del Chat / Formulario de Envío -->
    <div class="bg-spotify-dark border-t border-spotify-highlight/40 px-5 py-4">
      <form id="chat-form" class="flex gap-3">
        <!-- Inputs Ocultos de Sesión para lectura del script de Socket.IO -->
        <input type="hidden" id="session-user-name" value="<%= user.name %>">
        <input type="hidden" id="session-user-role" value="<%= user.role %>">

        <input 
          type="text" 
          id="message-input" 
          required 
          autocomplete="off" 
          placeholder="Escribe tu consulta de compatibilidad (Ej. ¿El disco VOL-D13 sirve para el Volvo FMX?)..." 
          class="flex-1 px-4 py-3 bg-spotify-black border border-spotify-highlight focus:border-spotify-orange focus:ring-1 focus:ring-spotify-orange text-white rounded-xl text-sm transition-all outline-none"
        >
        <button 
          type="submit" 
          class="flex items-center gap-2 bg-spotify-orange hover:bg-spotify-orangeHover text-white text-sm font-bold px-6 py-3 rounded-xl shadow-lg transition-all outline-none"
        >
          <span>Enviar</span>
          <i data-lucide="send" class="w-4 h-4"></i>
        </button>
      </form>
    </div>
  </div>
</div>

<!-- Cargar el módulo cliente de Socket.IO (servido por el backend) -->
<script src="/socket.io/socket.io.js"></script>

<!-- Lógica del Cliente de Socket.IO conectada al evento 'chat_message' -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Conectar a Socket.IO
    const socket = io();
    socket.emit('join_chat_room'); // F5: Unirse a la sala de soporte técnico

    // Elementos del DOM
    const chatMessages = document.getElementById('chat-messages');
    const chatForm = document.getElementById('chat-form');
    const messageInput = document.getElementById('message-input');
    const userName = document.getElementById('session-user-name').value;
    const userRole = document.getElementById('session-user-role').value;

    // Desplazar automáticamente al final
    const scrollToBottom = () => {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    };
    scrollToBottom();

    // Pintar mensaje en pantalla
    const displayMessage = (message) => {
      const isSelf = message.sender === userName;
      const roleLabel = message.role === 'support' ? 'Soporte' : (message.role === 'admin' ? 'Admin' : 'Mecánico');

      // Crear envoltorio
      const wrapper = document.createElement('div');
      wrapper.className = `flex items-start gap-3 max-w-[75%] animate-[fadeIn_0.25s_ease-out] ${isSelf ? 'ml-auto flex-row-reverse' : ''}`;

      // Icono o Avatar
      const avatar = document.createElement('div');
      avatar.className = `w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 border text-xs font-bold ${
        isSelf 
          ? 'bg-spotify-orange/15 border-spotify-orange text-spotify-orange' 
          : 'bg-spotify-highlight border-spotify-highlight text-gray-300'
      }`;
      avatar.textContent = message.sender.charAt(0).toUpperCase();

      // Burbuja
      const bubble = document.createElement('div');
      bubble.className = `p-3.5 shadow-md ${
        isSelf 
          ? 'bg-spotify-orange border border-spotify-orangeHover text-white rounded-l-xl rounded-br-xl' 
          : 'bg-spotify-dark border border-spotify-highlight text-gray-300 rounded-r-xl rounded-bl-xl'
      }`;

      // Cabecera
      const header = document.createElement('div');
      header.className = 'flex justify-between items-center gap-4 mb-1';
      
      const senderText = document.createElement('span');
      senderText.className = `text-xs font-bold ${isSelf ? 'text-white' : 'text-spotify-orange'}`;
      senderText.textContent = `${message.sender} (${roleLabel})`;

      const timeText = document.createElement('span');
      timeText.className = `text-[9px] font-semibold ${isSelf ? 'text-orange-200' : 'text-gray-600'}`;
      timeText.textContent = message.timestamp;

      header.appendChild(senderText);
      header.appendChild(timeText);

      // Cuerpo del mensaje (sanitizado contra XSS)
      const content = document.createElement('p');
      content.className = 'text-sm leading-relaxed whitespace-pre-wrap break-words';
      content.textContent = message.text;

      bubble.appendChild(header);
      bubble.appendChild(content);

      wrapper.appendChild(avatar);
      wrapper.appendChild(bubble);

      chatMessages.appendChild(wrapper);
    };

    // 📝 CORRECCIÓN DEL BUG: Escuchar el historial de chat cuando se conecta
    // Esto carga todos los mensajes previos de la BD
    socket.on('chat_history', (history) => {
      console.log(`📜 Cargando ${history.length} mensajes del historial...`);
      history.forEach(message => {
        displayMessage(message);
      });
      scrollToBottom();
    });

    // F5: Detección de escritura con debounce de 1.5 segundos
    let typingTimeout;
    let isTyping = false;

    messageInput.addEventListener('input', () => {
      if (!isTyping) {
        isTyping = true;
        socket.emit('typing', { sender: userName, role: userRole });
      }
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        isTyping = false;
        socket.emit('stop_typing');
      }, 1500);
    });

    // Enviar mensaje
    chatForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const text = messageInput.value.trim();
      if (!text) return;

      // Resetear el estado de escritura al enviar
      clearTimeout(typingTimeout);
      isTyping = false;
      socket.emit('stop_typing');

      const messageData = {
        sender: userName,
        role: userRole,
        text: text,
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      };

      // Emitir mensaje al servidor usando el evento 'chat_message'
      socket.emit('chat_message', messageData);

      messageInput.value = '';
      messageInput.focus();
    });

    // Escuchar mensajes transmitidos desde el servidor (solo sala support-room)
    socket.on('message', (message) => {
      displayMessage(message);
      scrollToBottom();
    });

    // F5: Mostrar/ocultar el indicador "está escribiendo..."
    const typingIndicator = document.getElementById('typing-indicator');
    const typingText = document.getElementById('typing-text');
    let stopTypingTimer;

    socket.on('user_typing', ({ sender, role }) => {
      const roleLabel = role === 'support' ? 'Soporte' : (role === 'admin' ? 'Admin' : 'Mecánico');
      typingText.textContent = `${sender} (${roleLabel}) está escribiendo...`;
      typingIndicator.classList.remove('hidden');
      clearTimeout(stopTypingTimer);
      // Seguro de caída: ocultar si no llega stop_typing
      stopTypingTimer = setTimeout(() => typingIndicator.classList.add('hidden'), 3000);
    });

    socket.on('user_stop_typing', () => {
      clearTimeout(stopTypingTimer);
      typingIndicator.classList.add('hidden');
    });
  });
</script>
