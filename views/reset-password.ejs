<%- include('partials/header') %>

<div class="auth-wrapper">
  <div class="glass-card auth-card">
    <div class="auth-header">
      <h2>Recuperar Contraseña</h2>
      <p>Restablece el acceso a tu portal de repuestos</p>
    </div>

    <% if (locals.error) { %>
      <div class="alert alert-error">
        <i data-lucide="alert-triangle"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/auth/reset-password" method="POST">
      <div class="form-group">
        <label for="email" class="form-label">Correo Electrónico Registrado</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="su.correo@empresa.com" required>
      </div>

      <div class="form-group">
        <label for="newPassword" class="form-label">Nueva Contraseña</label>
        <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Mínimo 6 caracteres" required>
      </div>

      <button type="submit" class="btn btn-primary btn-block">
        <i data-lucide="key-round"></i> Actualizar Contraseña
      </button>
    </form>

    <div style="margin-top: 1.5rem; text-align: center; font-size: 0.9rem;">
      <p><a href="/auth/login" style="color: var(--text-secondary);">Regresar al Inicio de Sesión</a></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
