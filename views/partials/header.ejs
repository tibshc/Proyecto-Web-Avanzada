<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Repuestos Pesados</title>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <!-- Tailwind CSS v3 CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <!-- Configuración personalizada de Tailwind -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            spotify: {
              black: '#121212',
              dark: '#181818',
              card: '#242424',
              highlight: '#2a2a2a',
              orange: '#f97316',
              orangeHover: '#ea580c'
            }
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            title: ['Outfit', 'sans-serif']
          }
        }
      }
    }
  </script>
  <style>
    /* Estilos personalizados adicionales para scrollbars y efectos finos */
    body {
      background-color: #121212;
      color: #e5e7eb;
    }
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #121212;
    }
    ::-webkit-scrollbar-thumb {
      background: #2a2a2a;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #3e3e3e;
    }
  </style>
</head>
<body class="flex flex-col min-h-full font-sans antialiased text-gray-200">
  <div class="flex flex-col flex-1">
    <!-- Navbar Premium Estilo macOS/Spotify -->
    <nav class="sticky top-0 z-50 bg-spotify-dark/80 backdrop-blur-md border-b border-spotify-highlight/40 px-6 py-4 flex justify-between items-center transition-all">
      <a href="/" class="flex items-center gap-3 group">
        <div class="bg-spotify-orange/10 p-2 rounded-lg border border-spotify-orange/30 group-hover:border-spotify-orange group-hover:bg-spotify-orange/20 transition-all duration-300">
          <i data-lucide="truck" class="text-spotify-orange w-6 h-6 filter drop-shadow-[0_0_8px_rgba(249,115,22,0.5)]"></i>
        </div>
        <span class="font-title font-extrabold text-xl tracking-tight text-white group-hover:text-spotify-orange transition-colors">
          Repuestos<span class="text-spotify-orange">Pesados</span>
        </span>
      </a>

      <ul class="flex items-center gap-6 list-none">
        <% if (locals.user) { %>
          <li>
            <a href="/dashboard" class="flex items-center gap-2 text-sm font-semibold transition-all duration-200 px-3 py-2 rounded-lg <%= title.includes('Catálogo') ? 'text-white bg-spotify-highlight' : 'text-gray-400 hover:text-white hover:bg-spotify-highlight/50' %>">
              <i data-lucide="layers" class="w-4 h-4"></i> Inventario
            </a>
          </li>
          <li>
            <a href="/chat" id="nav-chat-link" class="relative flex items-center gap-2 text-sm font-semibold transition-all duration-200 px-3 py-2 rounded-lg <%= title.includes('Soporte') ? 'text-white bg-spotify-highlight' : 'text-gray-400 hover:text-white hover:bg-spotify-highlight/50' %>">
              <i data-lucide="message-square" class="w-4 h-4"></i> Soporte en Vivo
              <%# Badge de mensajes no leídos — se llena dinámicamente por JS %>
              <span id="chat-badge" class="hidden absolute -top-1.5 -right-1.5 bg-red-500 text-white text-[9px] font-extrabold min-w-[18px] h-[18px] px-1 rounded-full flex items-center justify-center border-2 border-spotify-dark shadow-lg animate-bounce"></span>
            </a>
          </li>
          <li>
            <a href="/cart" class="relative flex items-center gap-2 text-sm font-semibold transition-all duration-200 px-3 py-2 rounded-lg <%= title.includes('Carrito') ? 'text-white bg-spotify-highlight' : 'text-gray-400 hover:text-white hover:bg-spotify-highlight/50' %>">
              <i data-lucide="shopping-cart" class="w-4.5 h-4.5 text-spotify-orange"></i> Carrito
              <% if (locals.cartCount && locals.cartCount > 0) { %>
                <span class="absolute -top-1 -right-1 bg-spotify-orange text-white text-[9px] font-extrabold w-4 h-4 rounded-full flex items-center justify-center border border-spotify-dark animate-bounce">
                  <%= cartCount %>
                </span>
              <% } %>
            </a>
          </li>
          <li class="flex items-center gap-2 text-xs font-bold text-spotify-orange bg-spotify-orange/10 border border-spotify-orange/20 px-3 py-1.5 rounded-full select-none">
            <span class="w-1.5 h-1.5 rounded-full bg-spotify-orange animate-pulse"></span>
            <span><%= user.name %> (<%= user.role === 'support' ? 'Soporte' : (user.role === 'admin' ? 'Admin' : 'Mecánico') %>)</span>
          </li>
          <li>
            <a href="/auth/logout" class="flex items-center gap-2 bg-spotify-highlight hover:bg-spotify-card border border-spotify-highlight hover:border-gray-600 text-white text-xs font-bold px-4 py-2 rounded-lg shadow-md hover:-translate-y-0.5 active:translate-y-0 transition-all duration-250">
              <i data-lucide="log-out" class="w-3.5 h-3.5"></i> Salir
            </a>
          </li>
        <% } else { %>
          <li>
            <a href="/auth/login" class="text-sm font-bold text-gray-400 hover:text-white transition-colors <%= title.includes('Iniciar') ? 'text-white' : '' %>">Ingresar</a>
          </li>
          <li>
            <a href="/auth/register" class="bg-spotify-orange hover:bg-spotify-orangeHover text-white text-sm font-bold px-5 py-2.5 rounded-lg shadow-lg hover:shadow-spotify-orange/20 hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200">
              Registrarse
            </a>
          </li>
        <% } %>
      </ul>
    </nav>

    <!-- Contenido Principal -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-8">

<% if (locals.user) { %>
<!-- ============================================================ -->
<!-- 🔔 SISTEMA DE NOTIFICACIONES DE CHAT EN TIEMPO REAL           -->
<!-- Se activa en todas las páginas excepto /chat                -->
<!-- ============================================================ -->
<style>
  #chat-notif-container {
    position: fixed; top: 80px; right: 20px; z-index: 9999;
    display: flex; flex-direction: column; gap: 10px;
    pointer-events: none; max-width: 340px;
  }
  .chat-notif-toast {
    background: #181818;
    border: 1px solid rgba(249,115,22,0.35);
    border-radius: 16px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.7), 0 0 0 1px rgba(249,115,22,0.1);
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 16px; pointer-events: auto;
    animation: notifSlideIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275) both;
    cursor: pointer; text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .chat-notif-toast:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 20px 56px rgba(0,0,0,0.75), 0 0 16px rgba(249,115,22,0.15);
  }
  .chat-notif-toast.hiding {
    animation: notifSlideOut 0.35s ease forwards;
  }
  .notif-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: rgba(249,115,22,0.12); border: 1.5px solid rgba(249,115,22,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 800; color: #f97316; flex-shrink: 0;
  }
  .notif-label {
    font-size: 9px; font-weight: 800; color: #f97316;
    text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 2px;
  }
  .notif-sender { font-size: 13px; font-weight: 700; color: #fff; }
  .notif-preview {
    font-size: 11px; color: #9ca3af; margin-top: 3px;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .notif-cta {
    font-size: 10px; color: #f97316; font-weight: 700;
    margin-top: 5px; display: flex; align-items: center; gap: 4px;
  }
  @keyframes notifSlideIn {
    from { opacity:0; transform: translateX(110%) scale(0.85); }
    to   { opacity:1; transform: translateX(0)   scale(1);    }
  }
  @keyframes notifSlideOut {
    to { opacity:0; transform: translateX(110%) scale(0.9); }
  }
</style>

<div id="chat-notif-container"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
(function() {
  // Solo actuar si el usuario está logueado
  const IS_CHAT_PAGE = window.location.pathname === '/chat';
  const STORAGE_KEY  = 'chat_unread_count';

  // --- Badge del navbar ---
  const badge    = document.getElementById('chat-badge');
  const navLink  = document.getElementById('nav-chat-link');

  // Leer contador persistido en sessionStorage
  let unreadCount = parseInt(sessionStorage.getItem(STORAGE_KEY) || '0', 10);

  function updateBadge(count) {
    if (!badge) return;
    if (count > 0 && !IS_CHAT_PAGE) {
      badge.textContent = count > 9 ? '9+' : String(count);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
      sessionStorage.removeItem(STORAGE_KEY);
    }
  }

  // Si entramos al chat, limpiar el contador
  if (IS_CHAT_PAGE) {
    unreadCount = 0;
    sessionStorage.removeItem(STORAGE_KEY);
    updateBadge(0);
  } else {
    updateBadge(unreadCount);
  }

  // --- Toast notification ---
  const container = document.getElementById('chat-notif-container');

  function showChatToast(sender, role, preview) {
    if (!container) return;

    const roleLabel = role === 'support' ? 'Soporte Técnico'
                    : role === 'admin'   ? 'Administrador'
                    :                      'Mecánico';

    const toast = document.createElement('a');
    toast.href = '/chat';
    toast.className = 'chat-notif-toast';
    toast.innerHTML = `
      <div class="notif-avatar">${sender.charAt(0).toUpperCase()}</div>
      <div style="flex:1;min-width:0;">
        <div class="notif-label">💬 Nuevo mensaje · ${roleLabel}</div>
        <div class="notif-sender">${sender}</div>
        <div class="notif-preview">${preview}</div>
        <div class="notif-cta">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Ir al chat de soporte
        </div>
      </div>
      <button onclick="event.preventDefault();event.stopPropagation();this.closest('a').remove();" style="background:none;border:none;color:#4b5563;cursor:pointer;padding:2px;line-height:1;font-size:14px;flex-shrink:0;align-self:flex-start;" title="Cerrar">×</button>
    `;

    container.appendChild(toast);

    // Auto-dismiss a los 6 segundos
    setTimeout(() => {
      toast.classList.add('hiding');
      setTimeout(() => toast.remove(), 380);
    }, 6000);
  }

  // --- Socket.IO: escuchar notificaciones globales ---
  const socket = io();

  socket.on('chat_notification', ({ sender, role, preview }) => {
    // No notificar si ya estamos en el chat (ya vemos los mensajes)
    if (IS_CHAT_PAGE) return;

    // Incrementar contador y persistir
    unreadCount++;
    sessionStorage.setItem(STORAGE_KEY, String(unreadCount));
    updateBadge(unreadCount);

    // Mostrar toast
    showChatToast(sender, role, preview);

    // Vibrar en móvil si está disponible
    if (navigator.vibrate) navigator.vibrate([80, 40, 80]);
  });
})();
</script>
<% } %>
